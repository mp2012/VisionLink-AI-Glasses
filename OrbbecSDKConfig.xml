<?xml version="1.0" encoding="UTF-8"?>
<Config>
    <Log>
        <!-- 完全关闭控制台日志（6=NONE），消除 "Wait for frame timeout" 等 SDK 内部噪音 -->
        <ConsoleLogLevel>6</ConsoleLogLevel>
        <FileLogLevel>6</FileLogLevel>
        <LogLevel>6</LogLevel>
        <Async>false</Async>
    </Log>
    <Memory>
        <!-- 内存池已恢复开启：之前的 OOM 是 df 引用泄漏导致，目前已修复 -->
        <EnableMemoryPool>true</EnableMemoryPool>
        <MaxFrameBufferSize>128</MaxFrameBufferSize>
        <PipelineFrameQueueSize>2</PipelineFrameQueueSize>
        <FrameProcessingBlockQueueSize>2</FrameProcessingBlockQueueSize>
    </Memory>
</Config>
